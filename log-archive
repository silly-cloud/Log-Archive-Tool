#!/bin/bash

####################################################
# Log Archive Tool
# Description: Archives log files older than a specified number of days.
# Usage: ./log-archive <log-directory> 
# Example: ./log-archive /var/log /backup/logs 30
####################################################

# Colors for output 
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if the correct number of arguments is provided
if [ "$#" -ne 1 ]; then
    echo -e "${RED}ERROR: Log directory not provided.${NC}"
    echo "Usage: $0 <log-directory>"
    exit 1
fi

LOG_DIR="$1"

if [ ! -d "$LOG_DIR" ]; then
    echo -e "${RED}ERROR: Directory $LOG_DIR does not exist.${NC}"
    exit 1
fi

# Create archive directory if it doesn't exist
ARCHIVE_DIR="./log_archives"
mkdir -p "$ARCHIVE_DIR"

TIMESTAMP=$(date +%Y%m%d_%H%M%S)

ARCHIVE_NAME="log_archive_${TIMESTAMP}.tar.gz"
ARCHIVE_PATH="$ARCHIVE_DIR/$ARCHIVE_NAME"

LOG_FILE="$ARCHIVE_DIR/archive.log"

echo -e "${YELLOW}Starting archive...${NC}"
echo "Archiving: $LOG_DIR"
echo "Output: $ARCHIVE_PATH"

if tar -czf "$ARCHIVE_PATH" -C "$(dirname "$LOG_DIR")" "$(basename "$LOG_DIR")" 2>/dev/null; then
    ARCHIVE_SIZE=$(du -h "$ARCHIVE_PATH" | cut -f1)

    # Log the archive details

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Archived: $ARCHIVE_NAME | Size: $ARCHIVE_SIZE | Source: $LOG_DIR" >> "$LOG_FILE"
    
    echo -e "${GREEN}✓ Archive successful!${NC}"
    echo "Archive: $ARCHIVE_NAME"
    echo "Size: $ARCHIVE_SIZE"
    echo "Location: $ARCHIVE_PATH"

else

    echo -e "${RED}Error: Failed to create archive${NC}"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAILED - $LOG_DIR" >> "$LOG_FILE"
    exit 1

fi 
